# Copy to .env and fill in.
ANTHROPIC_API_KEY=sk-ant-...
GROUP_PASSWORD=change-me
CHAINLIT_AUTH_SECRET=replace-with-openssl-rand-hex-32-output

# Where the reorganized data sits. Default points at this repo's sibling folder.
COUNTRY_DATA_DIR=./Country Data
CATALOG_DIR=./catalog

# Claude model.  Sonnet 4.6 is the recommended balance of capability and cost.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Safety defaults. Leave ALLOW_SENSITIVE_MODULES=false unless the deployment is private
# and your data-use terms allow geovariable/tracking access.
ALLOW_SENSITIVE_MODULES=false
MAX_RUN_PYTHON_STDOUT_CHARS=4000
MAX_RUN_PYTHON_STDERR_CHARS=2000
MAX_TOOL_RESULT_CHARS=12000
